const user = require("../db/models/user");

const music = require("../db/models/music");



const catchAsync = require("../utils/catchAsync");

const createMusic = catchAsync(async (req, res, next) => {
  const body = req.body;

  const newMusic = await music.create({
    title: body.title,
    // isFeatured: body.isFeatured,
    musicImage: body.musicImage,
    genre: body.genre,
    artist: body.artist,
    category: body.category,
    // year: body.year,
    // album: body.album,
    // duration: body.duration,
    musicUrl: body.musicUrl,
  });

  return res.status(201).json({
    status: "success",
    data: newMusic
  });
});

const getAllMusic = catchAsync(async (req, res, next) => {
  const allMusic = await music.findAll({include: user});

  return res.json({
    status: "success",
    data: allMusic
  });
});

const getMusicbyId = catchAsync(async (req, res, next) => {
  const musicId = req.params.id;
  const allMusic = await music.findByPk({include: user});
  if (!allMusic) {
    return next(new AppError("Invalid music ID", 400));
  }

  return res.json({
    status: "success",
    data: allMusic
  });
});

module.exports = {
  createMusic, getAllMusic, getMusicbyId
};